# ─────────────────────────────────────────────
# TradeHub 本地开发环境变量
# 复制为 .env 后修改
# ─────────────────────────────────────────────

# ── 基础设施端口（与 PowerTradeMain 完全隔离）──
# PowerTradeMain 占用：postgres:5432  redis:16379  tdengine:16041
# TradeHub 使用：      postgres:5433  redis:6380   tdengine:16042

POSTGRES_PASSWORD=tradehub_local_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

REDIS_URL=redis://localhost:6380/0

TDENGINE_HOST=localhost
TDENGINE_PORT=16042
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=stock_etf_ts

# ── 基金服务（Django）────────────────────────

FUND_DB=fundval
FUND_DB_USER=fundval
FUND_DB_PASSWORD=fundval_local
FUND_DB_PORT=5433

# Django 密钥（生产环境必须替换为强随机字符串）
SECRET_KEY=tradehub-insecure-local-key-change-in-production
DB_TYPE=postgresql

ALLOW_REGISTER=true
DEBUG=true
ALLOWED_HOSTS=*

CELERY_LOGLEVEL=info

# ── 股票服务（Go）──────────────────────────────

STOCK_DB=stock_etf
STOCK_DB_USER=stock
STOCK_DB_PASSWORD=tradehub_local_password
STOCK_DB_PORT=5433

# ── market-api ─────────────────────────────────

MARKET_API_URL=http://localhost:17080
XUEQIU_COOKIE=

# ── 本地业务服务端口（直接在宿主机启动）─────────

FUND_PORT=7001
STOCK_PORT=7002
MARKET_API_PORT=17080
FUND_RESEARCH_PORT=17081
FRONTEND_PORT=5173
